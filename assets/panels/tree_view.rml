<!--
  tree_view.rml — Hierarchical entity/scene tree with drag-drop support.
-->
<panel type="collapsible" title="Scene Graph">
    <tree-view id="scene-tree">
        <!-- Populated dynamically by C++ -->
        <tree-item type="group">Entities</tree-item>
        <tree-item id="entity-camera" data-entity-id="0">
            Camera
        </tree-item>
        <tree-item id="entity-grid" data-entity-id="1">
            Grid
        </tree-item>
    </tree-view>
</panel>
